,"editorMode":"ace/mode/markdown","editorHide":true,"tableHide":false},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<h3>Interpretation</h3>\n<p>The top ten movies represent the titles with the strongest average user ratings in the dataset.\n<br  />This result highlights the most highly appreciated movies among MovieLens users.</p>\n<p>However, average rating alone may favor movies with a small number of reviews.\n<br  />For a more robust ranking, a minimum rating threshold could also be applied.</p>\n"}]},"apps":[],"jobName":"paragraph_1780725692591_1720897495","id":"20260606-060132_1380747811","dateCreated":"2026-06-06T06:01:32+0000","dateStarted":"2026-06-06T06:04:22+0000","dateFinished":"2026-06-06T06:04:22+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20721"},{"text":"%md\n## Task iii: Users with at least 50 ratings and their favourite genre\n\nThis analysis is completed in two stages:\n\n1. Identify users who rated at least 50 movies.\n2. Determine each user's favourite genre by finding the genre they rated most frequently.\n\nBecause each movie may belong to multiple genres, the genre indicator columns are transformed into a normalized user-genre frequency table before ranking.\n\n\n","user":"anonymous","dateUpdated":"2026-06-06T06:26:39+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"scala"},"tableHide":false,"editorMode":"ace/mode/scala","editorHide":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<h2>Task iii: Users with at least 50 ratings and their favourite genre</h2>\n<p>This analysis is completed in two stages:</p>\n<ol>\n<li>Identify users who rated at least 50 movies.</li>\n<li>Determine each user's favourite genre by finding the genre they rated most frequently.</li>\n</ol>\n<p>Because each movie may belong to multiple genres, the genre indicator columns are transformed into a normalized user-genre frequency table before ranking.</p>\n"}]},"apps":[],"jobName":"paragraph_1780725861910_-1128139106","id":"20260606-060421_1557908465","dateCreated":"2026-06-06T06:04:21+0000","dateStarted":"2026-06-06T06:26:18+0000","dateFinished":"2026-06-06T06:26:18+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20722"},{"text":"%pyspark\n\nfrom pyspark.sql import functions as F\n\nactive_users = spark.sql(\"\"\"\n    SELECT user_id, COUNT(*) AS num_ratings\n    FROM ratings\n    GROUP BY user_id\n    HAVING COUNT(*) >= 50\n\"\"\")\n\nactive_users.createOrReplaceTempView(\"active_users\")\n\nactive_users.show(20, truncate=False)","user":"anonymous","dateUpdated":"2026-06-06T08:32:31+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"python"},"editorMode":"ace/mode/python"},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"+-------+-----------+\n|user_id|num_ratings|\n+-------+-----------+\n|148    |65         |\n|463    |133        |\n|496    |129        |\n|833    |267        |\n|243    |81         |\n|392    |111        |\n|540    |63         |\n|897    |185        |\n|251    |77         |\n|85     |288        |\n|451    |98         |\n|65     |80         |\n|458    |183        |\n|883    |268        |\n|255    |83         |\n|481    |56         |\n|588    |225        |\n|804    |332        |\n|296    |147        |\n|472    |263        |\n+-------+-----------+\nonly showing top 20 rows\n\n"}]},"apps":[],"jobName":"paragraph_1780725875400_780246087","id":"20260606-060435_570460612","dateCreated":"2026-06-06T06:04:35+0000","dateStarted":"2026-06-06T08:32:31+0000","dateFinished":"2026-06-06T08:32:48+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20723"},{"text":"%pyspark\r\nfrom pyspark.sql import functions as F\r\n\r\n# -------------------------\r\n# STEP 0: LOAD DATA AGAIN\r\n# -------------------------\r\n\r\nratings_df = spark.read.csv(\r\n    \"/user/maria_dev/ml-100k/u.data\",\r\n    sep=\"\\t\",\r\n    inferSchema=True\r\n).toDF(\"user_id\", \"movie_id\", \"rating\", \"rating_time\")\r\n\r\nitems_df = spark.read.csv(\r\n    \"/user/maria_dev/ml-100k/u.item\",\r\n    sep=\"|\",\r\n    inferSchema=True\r\n)\r\n\r\nusers_df = spark.read.csv(\r\n    \"/user/maria_dev/ml-100k/u.user\",\r\n    sep=\"|\",\r\n    inferSchema=True\r\n)\r\n\r\n# -------------------------\r\n# STEP 1: ACTIVE USERS\r\n# -------------------------\r\nactive_users = ratings_df.groupBy(\"user_id\") \\\r\n    .count() \\\r\n    .withColumnRenamed(\"count\", \"num_ratings\") \\\r\n    .filter(\"num_ratings >= 50\")\r\n\r\nactive_users.createOrReplaceTempView(\"active_users\")\r\n\r\n\r\n# -------------------------\r\n# STEP 2: ITEM GENRES (FIXED)\r\n# -------------------------\r\nitem_genres = items_df.selectExpr(\r\n    \"_c0 as item_id\",\r\n    \"\"\"\r\n    stack(19,\r\n        'unknown', _c5,\r\n        'action', _c6,\r\n        'adventure', _c7,\r\n        'animation', _c8,\r\n        'childrens', _c9,\r\n        'comedy', _c10,\r\n        'crime', _c11,\r\n        'documentary', _c12,\r\n        'drama', _c13,\r\n        'fantasy', _c14,\r\n        'film_noir', _c15,\r\n        'horror', _c16,\r\n        'musical', _c17,\r\n        'mystery', _c18,\r\n        'romance', _c19,\r\n        'sci_fi', _c20,\r\n        'thriller', _c21,\r\n        'war', _c22,\r\n        'western', _c23\r\n    ) as (genre, flag)\r\n    \"\"\"\r\n).filter(\"flag = 1\")\r\n\r\nitem_genres.createOrReplaceTempView(\"item_genres\")\r\n\r\n\r\n# -------------------------\r\n# STEP 3: USER-GENRE COUNTS\r\n# -------------------------\r\nuser_genre_counts = ratings_df \\\r\n    .join(active_users, \"user_id\") \\\r\n    .join(item_genres, ratings_df.movie_id == item_genres.item_id) \\\r\n    .groupBy(\"user_id\", \"genre\") \\\r\n    .count() \\\r\n    .withColumnRenamed(\"count\", \"genre_count\")\r\n\r\nuser_genre_counts.createOrReplaceTempView(\"user_genre_counts\")\r\n\r\n\r\n# -------------------------\r\n# STEP 4: FAVORITE GENRE\r\n# -------------------------\r\nfrom pyspark.sql.window import Window\r\n\r\nfav_genre_df = user_genre_counts \\\r\n    .withColumn(\r\n        \"rank\",\r\n        F.row_number().over(\r\n            Window.partitionBy(\"user_id\")\r\n            .orderBy(F.desc(\"genre_count\"), F.asc(\"genre\"))\r\n        )\r\n    ) \\\r\n    .filter(\"rank = 1\") \\\r\n    .drop(\"rank\")\r\n\r\n\r\nresult_task3 = active_users.join(fav_genre_df, \"user_id\") \\\r\n    .select(\"user_id\", \"num_ratings\", \"genre\", \"genre_count\") \\\r\n    .orderBy(F.desc(\"num_ratings\"))\r\n\r\nresult_task3.show(10, truncate=False)","user":"anonymous","dateUpdated":"2026-06-06T07:52:52+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"python"},"editorMode":"ace/mode/python"},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"+-------+-----------+------+-----------+\n|user_id|num_ratings|genre |genre_count|\n+-------+-----------+------+-----------+\n|405    |737        |drama |309        |\n|655    |685        |drama |410        |\n|13     |636        |drama |218        |\n|450    |540        |drama |237        |\n|276    |518        |drama |168        |\n|416    |493        |drama |212        |\n|537    |490        |drama |251        |\n|303    |484        |comedy|184        |\n|234    |480        |drama |213        |\n|393    |448        |comedy|191        |\n+-------+-----------+------+-----------+\nonly showing top 10 rows\n\n"}]},"apps":[],"jobName":"paragraph_1780727550255_1659019676","id":"20260606-063230_138773547","dateCreated":"2026-06-06T06:32:30+0000","dateStarted":"2026-06-06T07:52:53+0000","dateFinished":"2026-06-06T07:53:36+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20724"},{"text":"%md\r\n### Interpretation\r\n\r\nThis result identifies highly active users, defined as those who rated at least 50 movies, and determines the genre they interacted with most frequently.\r\n\r\nThe favourite genre is based on **rating frequency**, not rating score.  \r\nIn other words, it reflects the genre that appears most often among the movies rated by each user.\r\n\r\nThis analysis helps reveal user preference patterns and can be useful in recommendation systems or audience segmentation.\r\n","user":"anonymous","dateUpdated":"2026-06-06T07:53:45+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"markdown","editOnDblClick":true},"editorMode":"ace/mode/markdown","editorHide":true,"tableHide":false},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<h3>Interpretation</h3>\n<p>This result identifies highly active users, defined as those who rated at least 50 movies, and determines the genre they interacted with most frequently.</p>\n<p>The favourite genre is based on <strong>rating frequency</strong>, not rating score.\n<br  />In other words, it reflects the genre that appears most often among the movies rated by each user.</p>\n<p>This analysis helps reveal user preference patterns and can be useful in recommendation systems or audience segmentation.</p>\n"}]},"apps":[],"jobName":"paragraph_1780731485930_-485350697","id":"20260606-073806_519118199","dateCreated":"2026-06-06T07:38:06+0000","dateStarted":"2026-06-06T07:53:45+0000","dateFinished":"2026-06-06T07:53:47+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20725"},{"text":"%md\n## Task iv: Users younger than 20 years old\n\nThis query filters the users table to identify all users whose age is below 20.\n\n","user":"anonymous","dateUpdated":"2026-06-06T07:54:13+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"scala"},"editorMode":"ace/mode/scala","editorHide":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<h2>Task iv: Users younger than 20 years old</h2>\n<p>This query filters the users table to identify all users whose age is below 20.</p>\n"}]},"apps":[],"jobName":"paragraph_1780732424953_861943596","id":"20260606-075344_482323485","dateCreated":"2026-06-06T07:53:44+0000","dateStarted":"2026-06-06T07:54:10+0000","dateFinished":"2026-06-06T07:54:10+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20726"},{"text":"%pyspark\nusers_df.createOrReplaceTempView(\"users\")\n\nusers_df = users_df.toDF(\"user_id\", \"age\", \"gender\", \"occupation\", \"zip\")\nusers_df.createOrReplaceTempView(\"users\")","user":"anonymous","dateUpdated":"2026-06-06T07:58:57+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"python"},"editorMode":"ace/mode/python"},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[]},"apps":[],"jobName":"paragraph_1780732450236_-78736817","id":"20260606-075410_1917520788","dateCreated":"2026-06-06T07:54:10+0000","dateStarted":"2026-06-06T07:58:58+0000","dateFinished":"2026-06-06T07:59:02+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20727"},{"text":"%pyspark\r\n\r\nyoung_users = spark.sql(\"\"\"\r\n    SELECT user_id, age, gender, occupation, zip\r\n    FROM users\r\n    WHERE age < 20\r\n    ORDER BY age ASC, user_id ASC\r\n\"\"\")\r\n\r\nyoung_users.show(10, truncate=False)\r\nprint(\"Total users younger than 20:\", young_users.count())","user":"anonymous","dateUpdated":"2026-06-06T07:59:18+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"python"},"editorMode":"ace/mode/python"},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"+-------+---+------+----------+-----+\n|user_id|age|gender|occupation|zip  |\n+-------+---+------+----------+-----+\n|30     |7  |M     |student   |55436|\n|471    |10 |M     |student   |77459|\n|289    |11 |M     |none      |9
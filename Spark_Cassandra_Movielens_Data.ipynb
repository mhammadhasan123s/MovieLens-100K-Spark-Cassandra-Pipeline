","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20713"},{"text":"%spark2.sql\nSELECT title, avg_rating, rating_count\nFROM viz_movies\n","user":"anonymous","dateUpdated":"2026-06-06T08:19:50+0000","config":{"colWidth":12,"enabled":true,"results":{"0":{"graph":{"mode":"lineChart","height":300,"optionOpen":false},"helium":{}}},"editorSetting":{"language":"sql"},"editorMode":"ace/mode/sql"},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TABLE","data":"title\tavg_rating\trating_count\nStar Kid (1997)\t5.0\t3\nPrefontaine (1997)\t5.0\t3\nSaint of Fort Washington, The (1993)\t5.0\t2\nSanta with Muscles (1996)\t5.0\t2\nEntertaining Angels: The Dorothy Day Story (1996)\t5.0\t1\nThey Made Me a Criminal (1939)\t5.0\t1\nMarlene Dietrich: Shadow and Light (1996) \t5.0\t1\nGreat Day in Harlem, A (1994)\t5.0\t1\nSomeone Else's America (1995)\t5.0\t1\nAiqing wansui (1994)\t5.0\t1\nPather Panchali (1955)\t4.625\t8\nMaya Lin: A Strong Clear Vision (1994)\t4.5\t4\nAnna (1996)\t4.5\t2\nSome Mother's Son (1996)\t4.5\t2\nEverest (1998)\t4.5\t2\nClose Shave, A (1995)\t4.491\t112\nSchindler's List (1993)\t4.466\t298\nWrong Trousers, The (1993)\t4.466\t118\nCasablanca (1942)\t4.457\t243\nWallace & Gromit: The Best of Aardman Animation (1996)\t4.448\t67\n"}]},"apps":[],"jobName":"paragraph_1780723290750_746496573","id":"20260606-052130_1656990841","dateCreated":"2026-06-06T05:21:30+0000","dateStarted":"2026-06-06T05:28:36+0000","dateFinished":"2026-06-06T05:28:41+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20714"},{"text":"%md\r\n### Interpretation\r\n\r\nThe result shows the average rating for each movie based on user reviews.  \r\nMovies with higher average values were generally rated more positively by users.\r\n\r\nIncluding the number of ratings is important because a very high average based on only a few ratings may be less reliable than a slightly lower average based on many ratings.\r\n","user":"anonymous","dateUpdated":"2026-06-06T05:15:06+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"markdown","editOnDblClick":true},"editorMode":"ace/mode/markdown","editorHide":true,"tableHide":false},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<h3>Interpretation</h3>\n<p>The result shows the average rating for each movie based on user reviews.\n<br  />Movies with higher average values were generally rated more positively by users.</p>\n<p>Including the number of ratings is important because a very high average based on only a few ratings may be less reliable than a slightly lower average based on many ratings.</p>\n"}]},"apps":[],"jobName":"paragraph_1780721907353_-1691616691","id":"20260606-045827_20302521","dateCreated":"2026-06-06T04:58:27+0000","dateStarted":"2026-06-06T05:15:06+0000","dateFinished":"2026-06-06T05:15:06+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20715"},{"text":"%md\r\n## Task ii: Top ten movies with the highest average ratings\r\n\r\nThis query identifies the ten highest-rated movies by joining ratings with movie titles and sorting by average rating in descending order.\r\n","user":"anonymous","dateUpdated":"2026-06-06T08:20:18+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"markdown","editOnDblClick":true},"editorMode":"ace/mode/markdown","editorHide":true,"tableHide":false},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<h2>Task ii: Top ten movies with the highest average ratings</h2>\n<p>This query identifies the ten highest-rated movies by joining ratings with movie titles and sorting by average rating in descending order.</p>\n"}]},"apps":[],"jobName":"paragraph_1780722906639_-304944429","id":"20260606-051506_2147218475","dateCreated":"2026-06-06T05:15:06+0000","dateStarted":"2026-06-06T08:20:18+0000","dateFinished":"2026-06-06T08:20:19+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20716"},{"text":"%pyspark\nfrom pyspark.sql import functions as F\n\ntop10_movies = (\n    ratings_df\n    .join(items_df, \"item_id\")\n    .groupBy(\"item_id\", \"title\")\n    .agg(\n        F.round(F.avg(\"rating\"), 3).alias(\"avg_rating\"),\n        F.count(\"rating\").alias(\"rating_count\")\n    )\n    .orderBy(F.desc(\"avg_rating\"), F.desc(\"rating_count\"))\n    .limit(10)\n)\n\ntop10_movies.show(truncate=False)\n","user":"anonymous","dateUpdated":"2026-06-06T08:30:44+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"python","editOnDblClick":true},"editorMode":"ace/mode/python","editorHide":false,"tableHide":false},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"+-------+-------------------------------------------------+----------+------------+\n|item_id|title                                            |avg_rating|rating_count|\n+-------+-------------------------------------------------+----------+------------+\n|1189   |Prefontaine (1997)                               |5.0       |3           |\n|1293   |Star Kid (1997)                                  |5.0       |3           |\n|1467   |Saint of Fort Washington, The (1993)             |5.0       |2           |\n|1500   |Santa with Muscles (1996)                        |5.0       |2           |\n|1536   |Aiqing wansui (1994)                             |5.0       |1           |\n|814    |Great Day in Harlem, A (1994)                    |5.0       |1           |\n|1653   |Entertaining Angels: The Dorothy Day Story (1996)|5.0       |1           |\n|1201   |Marlene Dietrich: Shadow and Light (1996)        |5.0       |1           |\n|1122   |They Made Me a Criminal (1939)                   |5.0       |1           |\n|1599   |Someone Else's America (1995)                    |5.0       |1           |\n+-------+-------------------------------------------------+----------+------------+\n\n"}]},"apps":[],"jobName":"paragraph_1780724612168_123669659","id":"20260606-054332_1362879760","dateCreated":"2026-06-06T05:43:32+0000","dateStarted":"2026-06-06T06:03:24+0000","dateFinished":"2026-06-06T06:03:59+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20717"},{"text":"%pyspark\n\nfrom pyspark.sql import functions as F\n\nactive_users = spark.sql(\"\"\"\n    SELECT user_id, COUNT(*) AS num_ratings\n    FROM ratings\n    GROUP BY user_id\n    HAVING COUNT(*) >= 50\n\"\"\")\n\nactive_users.createOrReplaceTempView(\"active_users\")\n","user":"anonymous","dateUpdated":"2026-06-06T08:51:01+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"python"},"editorMode":"ace/mode/python"},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[]},"apps":[],"jobName":"paragraph_1780735836618_162821660","id":"20260606-085036_1703224002","dateCreated":"2026-06-06T08:50:36+0000","dateStarted":"2026-06-06T08:51:01+0000","dateFinished":"2026-06-06T08:51:02+0000","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:20718"},{"text":"%pyspark\n\nviz_active_users = active_users.orderBy(F.desc(\"num_ratings\")).limit(20)\nviz_active_users.createOrReplaceTempView(\"viz_active_users\")\n\nviz_active_users.show()\n","user":"anonymous","dateUpdated":"2026-06-06T08:51:19+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"python"},"editorMode":"ace/mode/python"},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"+-------+-----------+\n|user_id|num_ratings|\n+-------+-----------+\n|    405|        737|\n|    655|        685|\n|     13|        636|\n|    450|        540|\n|    276|        518|\n|    416|        493|\n|    537|        490|\n|    303|        484|\n|    234|        480|\n|    393|        448|\n|    181|        435|\n|    279|        434|\n|    429|        414|\n|    